{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Adagio",
  "version": "0.1.0",
  "identifier": "com.adagio.recorder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Adagio — Sound Recorder",
        "width": 1150,
        "height": 760,
        "minWidth": 880,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$AUDIO/**", "$APPDATA/**", "$HOME/Music/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.icns", "icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
