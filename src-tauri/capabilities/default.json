{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister"
  ]
}
